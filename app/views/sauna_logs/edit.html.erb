<% content_for :sauna_button_js do %>
  <%= javascript_import_module_tag "log_create_button" %>
<% end %>

<div class="max-w-2xl mx-auto p-4 flex flex-col items-center">
  <h1 class="text-2xl font-bold mb-6">サウナ記録の編集</h1>
  <%= form_with model: @sauna, class: "w-full space-y-8" do |f| %>
    <%= render 'form', f: f, sauna: @sauna %>
    <div class="mt-10 pb-10 text-center">
      <%= f.submit '更新する', class: "w-full md:w-2/3 py-4 bg-blue-600 text-white font-extrabold text-xl rounded-full shadow-xl" %>
    </div>
  <% end %>
</div>