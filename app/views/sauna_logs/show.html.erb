<div class="max-w-2xl mx-auto p-4 space-y-8">
  <%# ヘッダー・基本情報 %>
  <div class="text-center">
    <h1 class="text-3xl font-bold text-gray-800 mb-2"><%= @sauna.facility %></h1>
    <p class="text-gray-500"><%= @sauna.experience_date.strftime("%Y年%m月%d日") %></p>
  </div>

 
  <%# サウナセットの記録 %>
  <section class="space-y-4">
    <h2 class="text-xl font-bold border-l-4 border-blue-500 pl-3">サウナセット</h2>
    <div class="space-y-4">
      <% @sauna.sauna_sets.each_with_index do |set, index| %>
        <div class="bg-white border-2 border-blue-200 rounded-2xl p-5 shadow-sm relative overflow-hidden">
          <div class="absolute top-0 left-0 bg-blue-500 text-white px-3 py-1 text-xs font-bold rounded-br-lg">
            SET <%= index + 1 %>
          </div>
          <div class="grid grid-cols-3 gap-2 pt-4">
            <div class="text-center">
              <p class="text-xs text-gray-500">サウナ</p>
              <p class="font-bold"><%= set.heat_time %>分 / <%= set.heat_temperature %>℃</p>
            </div>
            <div class="text-center border-x border-gray-100">
              <p class="text-xs text-gray-500">水風呂</p>
              <p class="font-bold"><%= set.water_bath_time %>分 / <%= set.water_bath_temperature %>℃</p>
            </div>
            <div class="text-center">
              <p class="text-xs text-gray-500">外気浴</p>
              <p class="font-bold"><%= set.rest_time %>分</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# サウナ飯 %>
  <% if @sauna.sauna_meals.any? %>
    <section class="space-y-4">
      <h2 class="text-xl font-bold border-l-4 border-orange-400 pl-3">サウナ飯</h2>
      <div class="bg-orange-50 p-6 rounded-2xl border border-orange-200">
        <% @sauna.sauna_meals.each do |meal| %>
          <p class="text-lg font-bold text-orange-900">🍴 <%= meal.restaurant %></p>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# 感想 %>
  <section class="space-y-4">
    <h2 class="text-xl font-bold border-l-4 border-gray-400 pl-3">感想・メモ</h2>
    <div class="bg-gray-50 p-6 rounded-2xl border border-gray-200 min-h-[100px] whitespace-pre-wrap text-gray-700">
      <%= @sauna.comment %>
    </div>
  </section>

   <%# ステータス（満足度・混雑度） %>
  <div class="grid grid-cols-2 gap-4">
    <div class="bg-blue-50 p-4 rounded-xl border border-blue-100 text-center">
      <span class="block text-sm text-blue-600 font-bold mb-1">満足度</span>
      <span class="text-2xl font-black text-blue-900">★ <%= @sauna.satisfaction %> / 5</span>
    </div>
    <div class="bg-orange-50 p-4 rounded-xl border border-orange-100 text-center">
      <span class="block text-sm text-orange-600 font-bold mb-1">混雑度</span>
      <span class="text-2xl font-black text-orange-900"><%= @sauna.crowding %> / 5</span>
    </div>
  </div>

  <%# <div class="flex flex-col space-y-3 pt-6">

 

  <%# アクションボタン %>
  <div class="flex flex-col space-y-3 pt-6">
    <%= link_to '編集する', edit_sauna_log_path(@sauna), class: "w-full text-center py-3 bg-gray-800 text-white font-bold rounded-full hover:bg-gray-900 transition" %>
   <%= link_to '削除する', 
      sauna_log_path(@sauna), 
      data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか?' }, 
      class: "w-full text-center py-3 bg-red-600 text-white font-medium text-sm rounded hover:bg-red-700 transition" %>
    <%= link_to '一覧に戻る', sauna_logs_path, class: "w-full text-center py-3 text-gray-600 font-bold hover:underline" %>
  </div>
</div>
</div>