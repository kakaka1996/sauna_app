<% content_for :sauna_button_js do %>
  <%= javascript_import_module_tag "log_create_button" %>
<% end %>

<div class="max-w-2xl mx-auto p-4 flex flex-col items-center">
  <h1 class="text-2xl font-bold mb-6">サウナ記録</h1>
  <%= form_with model: @post_sauna_log, class: "w-full space-y-8" do |f| %>
    <%= render 'form', f: f, sauna: @post_sauna_log %>
    <div class="mt-10 pb-10 text-center">
      <%= f.submit 'サウナ記録を保存する', class: "w-full md:w-2/3 py-4 bg-green-600 text-white font-extrabold text-xl rounded-full shadow-xl" %>
    </div>
  <% end %>
</div>