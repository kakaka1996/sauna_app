<h2 class="flex flex-col place-items-center mt-20 font-bold">パスワードの再設定</h2>

<div class="flex flex-col items-center mx-auto">
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }, data: { turbo: false }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="container flex flex-col items-center mx-auto">
    <p class="text-sm text-gray-600 mb-5">登録済みのメールアドレスを入力してください。<br>パスワード再設定用のURLをお送りします。</p>

    <div class="field mb-5">
      <%= f.label :email, 'メールアドレス' %><br />
      <%= f.email_field :email, autofocus: true, class: "border-2 border-black mt-3", autocomplete: "email" %>
    </div>

    <div class="actions flex items-center gap-4">
      <%= f.submit "送信する", class: "py-1 px-3 border-2 border-black rounded cursor-pointer transition duration-150 active:scale-95 active:bg-gray-200" %>
      <%= link_to "ログインに戻る", new_user_session_path, class: "text-sm text-gray-500 hover:underline" %>
    </div>
  </div>
  <% end %>
</div>
