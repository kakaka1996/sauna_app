<header class="bg-sky-300 py-4">
  <div class="max-w-7xl mx-auto px-4 flex justify-between items-center text-white">
    <div class="flex items-center gap-6">
      <%= link_to "SAUNA_DAY", top_path, class: "group flex items-center gap-2 text-2xl font-black tracking-tighter sm:text-3xl transition-transform hover:scale-105" %>
      <%= link_to root_path, class: "hidden sm:block text-sm font-bold opacity-90 hover:opacity-100 border-b border-white pb-0.5 transition-all" do %>
        使い方はこちらから
      <% end %>
    </div>

    <nav>
      <% if user_signed_in? %>
        <details class="relative">
          <summary class="flex items-center gap-1 text-sm font-semibold opacity-90 hover:opacity-100 transition-all cursor-pointer list-none">
            <%= current_user.name %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="absolute right-0 mt-2 w-40 bg-white rounded-lg shadow-lg py-1 z-[9999]">
            <%= link_to "アカウント編集", edit_user_registration_path,
                class: "block px-4 py-2 text-sm text-gray-700 hover:bg-sky-50 hover:text-sky-600 transition-colors" %>
            <%= button_to "ログアウト", destroy_user_session_path,
                method: :delete,
                class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-sky-50 hover:text-sky-600 transition-colors bg-transparent border-none cursor-pointer" %>
          </div>
        </details>
      <% else %>
        <div class="flex items-center gap-4 sm:gap-6">
          <%= link_to "ログイン", new_user_session_path, data: { turbo: false }, class: "text-sm font-semibold opacity-90 hover:opacity-100 transition-all" %>
          <%= link_to "新規登録", new_user_registration_path, data: { turbo: false }, class: "px-4 py-2 text-sm font-bold bg-white text-sky-500 rounded-full shadow-sm hover:bg-sky-50 transition-colors" %>
        </div>
      <% end %>
    </nav>
  </div>
</header>
