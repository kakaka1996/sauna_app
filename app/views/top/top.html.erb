<% content_for :google_map_js do %>
   <%= javascript_import_module_tag "google_map" %>
 <% end %>
 
<div class="w-full px-4 py-6">
    <div class="relative w-full h-[500px] rounded-xl overflow-hidden border border-slate-200 shadow-sm">
        <div id="map" style="height: 500px; width: 100%;"></div>

        <div id="route_info_panel" class="hidden absolute top-3 right-3 z-10">
            <div class="bg-white/90 backdrop-blur px-4 py-2 rounded-lg border border-slate-200 shadow-sm flex flex-col items-end">
                <div class="flex items-baseline gap-1">
                    <span id="duration_text" class="text-lg font-bold text-slate-800">--分</span>
                    <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">所要時間</span>
                </div>
                <div id="distance_text" class="text-[11px] text-slate-500 font-medium">-- km</div>
            </div>
        </div>
    </div>
</div>



    <div class="max-w-xl mx-auto mt-6 flex flex-col gap-4">
        <div class="flex gap-2">
            <input type="text" id="place_search" placeholder="サウナ施設を検索..." 
                   class="flex-1 px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500/20 focus:border-sky-500 transition-all">
            <button id="search_execution" 
                    class="px-5 py-2 bg-sky-500 text-white text-sm font-bold rounded-lg hover:bg-sky-600 transition-colors">
                検索
            </button>
        </div>
        <button id="route_search" 
                class="w-full py-2 bg-white text-sky-600 border border-sky-200 text-sm font-bold rounded-lg hover:bg-slate-50 transition-colors">
            現在地からのルートを表示
        </button>
    </div>
</div>