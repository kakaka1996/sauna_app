<div class="max-w-2xl mx-auto p-4 space-y-6">
  <h1 class="text-2xl font-bold text-gray-800">★ お気に入り施設</h1>

  <% if @favorites.empty? %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg">まだお気に入りに追加した施設がありません</p>
      <%= link_to "施設を検索する", top_path, class: "mt-4 inline-block text-sm text-sky-500 hover:underline" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @favorites.each do |favorite| %>
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-md transition-shadow p-4 flex items-center gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-yellow-100 flex items-center justify-center">
            <span class="text-yellow-500 text-xl">★</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-gray-800 truncate"><%= favorite.name %></p>
            <% if favorite.address.present? %>
              <p class="text-sm text-gray-500 mt-0.5 truncate"><%= favorite.address %></p>
            <% end %>
            <p class="text-xs text-gray-400 mt-1"><%= favorite.created_at.strftime("%Y年%m月%d日") %> 追加</p>
          </div>
          <div class="flex-shrink-0 flex items-center gap-2">
            <%= link_to top_path, class: "text-xs text-sky-500 hover:underline" do %>
              検索
            <% end %>
            <%= button_to favorite_facility_path(favorite), method: :delete,
                class: "text-gray-300 hover:text-red-400 transition-colors bg-transparent border-none cursor-pointer text-xl leading-none",
                title: "お気に入りから削除",
                data: { turbo_confirm: "お気に入りから削除しますか？" } do %>
              ★
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
